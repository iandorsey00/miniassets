{
  "name": "miniassets",
  "version": "0.1.7",
  "description": "MiniAssets - bilingual household asset management with MiniAuth",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19 || ^22.12 || ^24.0"
  },
  "scripts": {
    "dev": "prisma generate && next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "prisma generate && eslint .",
    "db:push": "prisma db push && prisma generate",
    "db:apply": "bash scripts/apply-schema.sh",
    "db:init": "mkdir -p data && if [ ! -f data/miniassets.db ]; then prisma migrate diff --from-empty --to-schema prisma/schema.prisma --script | sqlite3 data/miniassets.db; fi && prisma generate",
    "db:seed": "prisma generate && node --experimental-strip-types prisma/seed.ts"
  },
  "dependencies": {
    "@fontsource-variable/noto-sans-sc": "^5.2.10",
    "@fontsource/inter": "^5.2.8",
    "@prisma/adapter-better-sqlite3": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@zxing/browser": "^0.1.5",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.4.0",
    "lucide-react": "^1.7.0",
    "next": "^16.2.2",
    "prisma": "^7.6.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.2",
    "typescript": "^5.9.3"
  }
}
